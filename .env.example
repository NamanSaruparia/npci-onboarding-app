# Copy to .env.local for local dev. Set the same keys in your host (Vercel, Docker, etc.).

# Required at runtime whenever API routes call connectDB()
MONGODB_URI=mongodb://127.0.0.1:27017/npci-onboarding

# Optional: when set, admin routes require header X-Admin-Key: <value>
# ADMIN_ACCESS_KEY=

# Optional — email notifications (UEM approval, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# UEM_TEAM_EMAIL=team@example.com

# Optional — fixed OTP in dev when testing login flows
# DUMMY_OTP=123456
